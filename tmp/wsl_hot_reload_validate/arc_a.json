{
  "listen": "127.0.0.1:8080",
  "admin_listen": "127.0.0.1:9900",
  "workers": 4,
  "linger_ms": 300,
  "io_uring": {
    "entries": 4096,
    "accept_multishot": true,
    "tick_ms": 10,
    "sqpoll": true,
    "sqpoll_idle_ms": 0,
    "iopoll": false
  },
  "buffers": {
    "buf_size": 8192,
    "buf_count": 1024
  },
  "timeouts_ms": {
    "cli_read": 30000,
    "up_conn": 3000,
    "up_write": 30000,
    "up_read": 30000,
    "cli_write": 30000
  },
  "upstreams": [
    {"name": "app_a", "addr": "127.0.0.1:3000", "keepalive": 1024, "idle_ttl_ms": 30000},
    {"name": "app_b", "addr": "127.0.0.1:3001", "keepalive": 1024, "idle_ttl_ms": 30000}
  ],
  "plugins": [],
  "routes": [
    {
      "path": "/*",
      "upstream": "app_a",
      "plugins": [],
      "rate_limit": null
    }
  ]
}

{
  "listen": "127.0.0.1:18083",
  "admin_listen": "127.0.0.1:19903",
  "workers": 1,
  "require_upstream_mtls": false,
  "io_uring": {
    "entries": 512,
    "accept_multishot": false,
    "tick_ms": 5,
    "sqpoll": false,
    "sqpoll_idle_ms": 0,
    "iopoll": false
  },
  "buffers": { "buf_size": 8192, "buf_count": 256 },
  "timeouts_ms": {
    "cli_read": 1000,
    "up_conn": 1000,
    "up_write": 1000,
    "up_read": 1000,
    "cli_write": 1000
  },
  "upstreams": [
    { "name": "main", "addr": "127.0.0.1:19280", "keepalive": 8, "idle_ttl_ms": 1000 },
    { "name": "shadow", "addr": "127.0.0.1:19281", "keepalive": 8, "idle_ttl_ms": 1000 }
  ],
  "plugins": [],
  "routes": [
    {
      "path": "/x",
      "upstream": "main",
      "mirror": "shadow"
    }
  ]
}

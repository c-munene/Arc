{
  "listen": "0.0.0.0:8080",
  "admin_listen": "127.0.0.1:9900",
  "control_plane": {
    "enabled": false,
    "bind": "127.0.0.1:19998",
    "role": "standalone",
    "node_id": "arc-node-1",
    "peers": [],
    "quorum": 0,
    "auth_token": null,
    "pull_from": null,
    "pull_interval_ms": 1000,
    "peer_timeout_ms": 1200
  },
  "global_rate_limit": {
    "backend": "redis",
    "redis": {
      "url": "redis://127.0.0.1:6379/0",
      "budget_ms": 2,
      "circuit_open_ms": 500
    }
  },
  "workers": 0,
  "linger_ms": 300,
  "io_uring": {
    "entries": 4096,
    "accept_multishot": true,
    "tick_ms": 10,
    "sqpoll": true,
    "sqpoll_idle_ms": 0,
    "iopoll": false
  },
  "buffers": {
    "buf_size": 8192,
    "buf_count": 0
  },
  "timeouts_ms": {
    "cli_handshake": 3000,
    "cli_read": 30000,
    "up_conn": 3000,
    "up_handshake": 3000,
    "up_write": 30000,
    "up_read": 30000,
    "cli_write": 30000
  },
  "require_upstream_mtls": false,
  "upstreams": [
    {
      "name": "default",
      "addr": "127.0.0.1:9000",
      "keepalive": 1024,
      "idle_ttl_ms": 30000
    }
  ],
  "plugins": [],
  "routes": [
    {
      "path": "/",
      "upstream": "default",
      "plugins": [],
      "rate_limit": {
        "rps": 100000,
        "burst": 200000
      }
    },
    {
      "path": "/static/*",
      "upstream": "default",
      "plugins": [],
      "rate_limit": null
    }
  ]
}

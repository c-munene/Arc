node:
  id: "arc-dev"
  workers: 0
  max_connections: 0
  read_timeout: 30s
  write_timeout: 30s
  idle_timeout: 60s

listeners:
  - name: "http"
    kind: http
    bind: "0.0.0.0:8080"
    socket:
      so_reuseport: true
  - name: "https"
    kind: https
    bind: "0.0.0.0:8443"
    tls:
      certificates:
        - sni: "localhost"
          cert_pem: "./certs/dev.crt.pem"
          key_pem: "./certs/dev.key.pem"

upstreams:
  - name: "app"
    discovery:
      type: static
      endpoints:
        - address: "127.0.0.1:3000"
          weight: 1
        - address: "127.0.0.1:3001"
          weight: 1
    lb:
      algorithm: peak_ewma
      decay: 10s

routes:
  - name: "root"
    match:
      host: ["localhost"]
      methods: ["GET", "POST"]
      path: "/{*rest}"
      headers: []
      cookies: []
      query: []
    action:
      upstream: "app"
      retry:
        max_retries: 1
        backoff: 50ms
        idempotent_only: true

plugins: {}

observability:
  metrics_enabled: true
  metrics_bind: "127.0.0.1:9090"
  access_log:
    enabled: true
    sample: 1.0
    disabled_routes: []

control_plane:
  enabled: true
  bind: "127.0.0.1:9900"
